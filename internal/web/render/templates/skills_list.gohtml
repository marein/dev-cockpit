{{define "skills_list.gohtml"}}
{{template "app_start.gohtml" .}}
{{template "coder_page_start.gohtml" .CoderNav}}
{{if .Skills}}
<div class="list-group list-group-hoverable">
  {{range .Skills}}
  <div class="list-group-item">
    <div class="row g-2 align-items-start">
      <div class="col min-w-0">
        <a href="{{$.Base}}/skills/{{.ID}}/edit" class="text-reset text-decoration-none fw-medium text-break">{{.ID}}</a>
        <div class="text-secondary small text-break">{{if .Description}}{{.Description}}{{else}}No description{{end}}</div>
      </div>
      <div class="col-auto">
        <div class="btn-list flex-nowrap">
          <a href="{{$.Base}}/skills/{{.ID}}/edit" class="btn btn-sm btn-icon btn-outline-secondary" aria-label="Edit skill {{.ID}}" title="Edit"><i class="ti ti-pencil"></i></a>
          <form method="post" action="{{$.Base}}/skills/{{.ID}}/delete" data-confirm="Delete skill &quot;{{.ID}}&quot;?" data-confirm-button="Delete">
            <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}">
            <button type="submit" class="btn btn-sm btn-icon btn-outline-danger" aria-label="Delete skill {{.ID}}" title="Delete"><i class="ti ti-trash"></i></button>
          </form>
        </div>
      </div>
    </div>
  </div>
  {{end}}
</div>
<div class="d-grid gap-2 d-sm-flex justify-content-sm-end mt-3">
  <a href="{{.Base}}/skills/new" class="btn btn-primary"><i class="ti ti-plus me-1"></i> Create skill</a>
</div>
{{else}}
<div class="empty">
  <div class="empty-icon"><i class="ti ti-tool fs-1"></i></div>
  <p class="empty-title">No skills defined</p>
  <div class="empty-action">
    <a href="{{.Base}}/skills/new" class="btn btn-primary"><i class="ti ti-plus me-1"></i> Create skill</a>
  </div>
</div>
{{end}}
{{template "coder_page_end.gohtml"}}
{{template "app_end.gohtml" .}}
{{end}}
