{{define "project_breadcrumb.gohtml"}}
<div class="page-pretitle">
  {{if .}}
  <a href="/projects#project-{{.}}" class="link-secondary text-decoration-none d-inline-block mw-100 text-truncate align-bottom">
    <i class="ti ti-arrow-left me-1"></i>{{.}}
  </a>
  {{else}}
  <a href="/projects" class="link-secondary text-decoration-none d-inline-block mw-100 text-truncate align-bottom">
    <i class="ti ti-arrow-left me-1"></i>Projects
  </a>
  {{end}}
</div>
{{end}}
