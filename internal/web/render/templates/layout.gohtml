{{define "html_head.gohtml"}}{{$appName := "Dev Cockpit"}}<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover"/>
  <meta name="color-scheme" content="light dark">
  <meta name="theme-color" media="(prefers-color-scheme: light)" content="#f9fafb">
  <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#111827">
  <script>window.matchMedia("(prefers-color-scheme:dark)").matches && document.documentElement.setAttribute('data-bs-theme', 'dark');</script>
  <meta name="csrf-token" content="{{.CSRFToken}}">
  <meta name="dc-jingle" content="{{.Jingle}}">
  <meta name="dc-build" content="{{assetBuild}}">
  <title>{{if .Title}}{{.Title}} - {{end}}{{$appName}}</title>
  <link rel="icon" href="{{asset "/favicon.svg"}}" type="image/svg+xml">
  <link rel="apple-touch-icon" href="{{asset "/app-icon-180.png"}}">
  <link rel="manifest" href="{{asset "/manifest.json"}}">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/core@1.4.0/dist/css/tabler.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.44.0/dist/tabler-icons.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@xterm/xterm@5.5.0/css/xterm.min.css">
  <link rel="stylesheet" href="{{asset "/css/style.css"}}">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@xterm/xterm@5.5.0/lib/xterm.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@xterm/addon-fit@0.11.0/lib/addon-fit.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@xterm/addon-canvas@0.7.0/lib/addon-canvas.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@xterm/addon-web-links@0.11.0/lib/addon-web-links.min.js"></script>
  <script type="importmap">
  {
    "imports": {
      "@dc/dom": "{{asset "/js/dc/dom.js"}}",
      "@dc/events": "{{asset "/js/dc/events.js"}}",
      "@dc/store": "{{asset "/js/dc/store.js"}}",
      "@dc/repeater": "{{asset "/js/dc/repeater.js"}}",
      "@dc/project-sort": "{{asset "/js/dc/project-sort.js"}}",
      "@dc/fold": "{{asset "/js/dc/fold.js"}}",
      "@dc/toast": "{{asset "/js/dc/toast.js"}}",
      "@dc/dialog": "{{asset "/js/dc/dialog.js"}}",
      "@dc/contextmenu": "{{asset "/js/dc/contextmenu.js"}}",
      "@dc/http": "{{asset "/js/dc/http.js"}}",
      "@dc/jingle": "{{asset "/js/dc/jingle.js"}}",
      "dc-quicknav": "{{asset "/js/components/quicknav.js"}}",
      "dc-notifications": "{{asset "/js/components/notifications.js"}}",
      "dc-update-check": "{{asset "/js/components/update-check.js"}}",
      "dc-project-list": "{{asset "/js/components/project-list.js"}}",
      "dc-collapse-list": "{{asset "/js/components/collapse-list.js"}}",
      "dc-coder-select": "{{asset "/js/components/coder-select.js"}}",
      "dc-inline-rename": "{{asset "/js/components/inline-rename.js"}}",
      "dc-editor": "{{asset "/js/components/editor.js"}}",
      "dc-jingle-picker": "{{asset "/js/components/jingle-picker.js"}}",
      "dc-notify-volume": "{{asset "/js/components/notify-volume.js"}}",
      "dc-push-settings": "{{asset "/js/components/push-settings.js"}}",
      "coder-file-upload": "{{asset "/js/components/coder-file-upload.js"}}",
      "terminal-attach": "{{asset "/js/components/terminal-attach.js"}}",
      "terminal-tabs": "{{asset "/js/components/terminal-tabs.js"}}",
      "terminal-input": "{{asset "/js/components/terminal-input.js"}}",
      "terminal-setting-select": "{{asset "/js/components/terminal-setting-select.js"}}",
      "terminal-scroll-zone": "{{asset "/js/components/terminal-scroll-zone.js"}}",
      "terminal-swipe-nav": "{{asset "/js/components/terminal-swipe-nav.js"}}",
      "terminal-direction-pad": "{{asset "/js/components/terminal-direction-pad.js"}}",
      "@marein/js-scriptune": "https://cdn.jsdelivr.net/npm/@marein/js-scriptune@0.0.1/src/scriptune.min.js",
      "@codemirror/autocomplete": "https://cdn.jsdelivr.net/npm/@codemirror/autocomplete@6.17.0/dist/index.js",
      "@codemirror/commands": "https://cdn.jsdelivr.net/npm/@codemirror/commands@6.6.0/dist/index.js",
      "@codemirror/lang-cpp": "https://cdn.jsdelivr.net/npm/@codemirror/lang-cpp@6.0.2/dist/index.js",
      "@codemirror/lang-css": "https://cdn.jsdelivr.net/npm/@codemirror/lang-css@6.2.1/dist/index.js",
      "@codemirror/lang-go": "https://cdn.jsdelivr.net/npm/@codemirror/lang-go@6.0.0/dist/index.js",
      "@codemirror/lang-html": "https://cdn.jsdelivr.net/npm/@codemirror/lang-html@6.4.9/dist/index.js",
      "@codemirror/lang-java": "https://cdn.jsdelivr.net/npm/@codemirror/lang-java@6.0.1/dist/index.js",
      "@codemirror/lang-javascript": "https://cdn.jsdelivr.net/npm/@codemirror/lang-javascript@6.2.2/dist/index.js",
      "@codemirror/lang-json": "https://cdn.jsdelivr.net/npm/@codemirror/lang-json@6.0.1/dist/index.js",
      "@codemirror/lang-markdown": "https://cdn.jsdelivr.net/npm/@codemirror/lang-markdown@6.2.5/dist/index.js",
      "@codemirror/lang-php": "https://cdn.jsdelivr.net/npm/@codemirror/lang-php@6.0.1/dist/index.js",
      "@codemirror/lang-python": "https://cdn.jsdelivr.net/npm/@codemirror/lang-python@6.1.6/dist/index.js",
      "@codemirror/lang-rust": "https://cdn.jsdelivr.net/npm/@codemirror/lang-rust@6.0.1/dist/index.js",
      "@codemirror/lang-sql": "https://cdn.jsdelivr.net/npm/@codemirror/lang-sql@6.7.0/dist/index.js",
      "@codemirror/lang-xml": "https://cdn.jsdelivr.net/npm/@codemirror/lang-xml@6.1.0/dist/index.js",
      "@codemirror/lang-yaml": "https://cdn.jsdelivr.net/npm/@codemirror/lang-yaml@6.1.1/dist/index.js",
      "@codemirror/language": "https://cdn.jsdelivr.net/npm/@codemirror/language@6.10.2/dist/index.js",
      "@codemirror/lint": "https://cdn.jsdelivr.net/npm/@codemirror/lint@6.8.1/dist/index.js",
      "@codemirror/search": "https://cdn.jsdelivr.net/npm/@codemirror/search@6.5.6/dist/index.js",
      "@codemirror/state": "https://cdn.jsdelivr.net/npm/@codemirror/state@6.4.1/dist/index.js",
      "@codemirror/theme-one-dark": "https://cdn.jsdelivr.net/npm/@codemirror/theme-one-dark@6.1.2/dist/index.js",
      "@codemirror/view": "https://cdn.jsdelivr.net/npm/@codemirror/view@6.26.3/dist/index.js",
      "@lezer/common": "https://cdn.jsdelivr.net/npm/@lezer/common@1.2.3/dist/index.js",
      "@lezer/cpp": "https://cdn.jsdelivr.net/npm/@lezer/cpp@1.1.6/dist/index.js",
      "@lezer/css": "https://cdn.jsdelivr.net/npm/@lezer/css@1.3.3/dist/index.js",
      "@lezer/go": "https://cdn.jsdelivr.net/npm/@lezer/go@1.0.1/dist/index.js",
      "@lezer/highlight": "https://cdn.jsdelivr.net/npm/@lezer/highlight@1.2.1/dist/index.js",
      "@lezer/html": "https://cdn.jsdelivr.net/npm/@lezer/html@1.3.13/dist/index.js",
      "@lezer/java": "https://cdn.jsdelivr.net/npm/@lezer/java@1.1.3/dist/index.js",
      "@lezer/javascript": "https://cdn.jsdelivr.net/npm/@lezer/javascript@1.5.4/dist/index.js",
      "@lezer/json": "https://cdn.jsdelivr.net/npm/@lezer/json@1.0.3/dist/index.js",
      "@lezer/lr": "https://cdn.jsdelivr.net/npm/@lezer/lr@1.4.2/dist/index.js",
      "@lezer/markdown": "https://cdn.jsdelivr.net/npm/@lezer/markdown@1.6.4/dist/index.js",
      "@lezer/php": "https://cdn.jsdelivr.net/npm/@lezer/php@1.0.5/dist/index.js",
      "@lezer/python": "https://cdn.jsdelivr.net/npm/@lezer/python@1.1.19/dist/index.js",
      "@lezer/rust": "https://cdn.jsdelivr.net/npm/@lezer/rust@1.0.2/dist/index.js",
      "@lezer/xml": "https://cdn.jsdelivr.net/npm/@lezer/xml@1.0.6/dist/index.js",
      "@lezer/yaml": "https://cdn.jsdelivr.net/npm/@lezer/yaml@1.0.4/dist/index.js",
      "codemirror": "https://cdn.jsdelivr.net/npm/codemirror@6.0.1/dist/index.js",
      "crelt": "https://cdn.jsdelivr.net/npm/crelt@1.0.6/index.js",
      "style-mod": "https://cdn.jsdelivr.net/npm/style-mod@4.1.3/src/style-mod.js",
      "w3c-keyname": "https://cdn.jsdelivr.net/npm/w3c-keyname@2.2.8/index.js"
    }
  }
  </script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script type="module" src="{{asset "/js/pe.js"}}"></script>
  <script type="module" src="{{asset "/js/components/app.js"}}"></script>
</head>
{{end}}

{{define "login_start.gohtml"}}{{template "html_head.gohtml" .}}{{$appName := "Dev Cockpit"}}
<body>
  <div data-page-content>
  <div class="page page-center">
    <div class="container container-tight py-4">
      <div class="text-center mb-4">
        <a href="/login" class="navbar-brand navbar-brand-autodark justify-content-center text-reset text-decoration-none" aria-label="{{$appName}}">
          <i class="ti ti-dashboard fs-1 me-2" aria-hidden="true"></i>
          <span>{{$appName}}</span>
        </a>
      </div>
      {{if .Flash.Message}}
      <div class="alert alert-{{if eq .Flash.Level "success"}}success{{else}}danger{{end}} alert-dismissible" role="alert">
        <div class="d-flex">
          <i class="ti {{if eq .Flash.Level "success"}}ti-circle-check{{else}}ti-alert-circle{{end}} me-2 fs-3"></i>
          <div class="text-break">{{.Flash.Message}}</div>
        </div>
        <a class="btn-close" data-bs-dismiss="alert" aria-label="close"></a>
      </div>
      {{end}}
{{end}}

{{define "login_end.gohtml"}}
    </div>
  </div>
  </div>
</body>
</html>{{end}}

{{define "app_start.gohtml"}}{{template "html_head.gohtml" .}}{{$appName := "Dev Cockpit"}}
<body>
  <div data-page-content>
  <div class="page">
    <header class="navbar navbar-expand-md d-print-none d-md-none">
      <div class="container-xl">
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbar-menu" aria-controls="navbar-menu" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="navbar-brand navbar-brand-autodark d-none-navbar-horizontal mx-auto mx-md-0 pe-0 pe-md-3">
          <a href="/projects" class="d-flex align-items-center gap-2 text-reset text-decoration-none" aria-label="{{$appName}}">
            <i class="ti ti-dashboard fs-2" aria-hidden="true"></i>
            <span>{{$appName}}</span>
          </a>
        </div>
        <div class="d-md-none d-flex align-items-center gap-2">
          <button type="button" class="js-update-flag d-none btn btn-icon btn-outline-primary" data-update-open aria-label="Update available">
            <i class="ti ti-arrow-up-circle"></i>
          </button>
          {{if .User}}<dc-notifications>{{template "notify_bell.gohtml" .}}</dc-notifications>{{else}}
          <span class="navbar-toggler invisible" aria-hidden="true" tabindex="-1">
            <span class="navbar-toggler-icon"></span>
          </span>
          {{end}}
        </div>
      </div>
    </header>
    <header class="navbar-expand-md">
      <div class="collapse navbar-collapse" id="navbar-menu">
        <div class="navbar">
          <div class="container-xl">
            <div class="navbar-brand navbar-brand-autodark d-none d-md-flex pe-3">
              <a href="/projects" class="d-flex align-items-center gap-2 text-reset text-decoration-none" aria-label="{{$appName}}">
                <i class="ti ti-dashboard fs-2" aria-hidden="true"></i>
                <span>{{$appName}}</span>
              </a>
            </div>
            <div class="row flex-column flex-md-row flex-fill align-items-center">
              <div class="col">
                <ul class="navbar-nav">
                  <li class="nav-item">
                    <a class="nav-link {{if eq .ActiveTab "projects"}}active{{end}}" href="/projects">
                      <span class="nav-link-icon d-md-none d-lg-inline-block"><i class="ti ti-folders"></i></span>
                      <span class="nav-link-title">Projects</span>
                    </a>
                  </li>
                  <li class="nav-item">
                    <a class="nav-link {{if eq .ActiveTab "coder"}}active{{end}}" href="{{.CoderHome}}">
                      <span class="nav-link-icon d-md-none d-lg-inline-block"><i class="ti ti-code-ai"></i></span>
                      <span class="nav-link-title">Coder</span>
                    </a>
                  </li>
                  <li class="nav-item">
                    <a class="nav-link {{if eq .ActiveTab "settings"}}active{{end}}" href="/settings/notifications">
                      <span class="nav-link-icon d-md-none d-lg-inline-block"><i class="ti ti-settings"></i></span>
                      <span class="nav-link-title">Settings</span>
                    </a>
                  </li>
                  {{if .User}}
                  <li class="nav-item d-md-none">
                    <hr class="my-2">
                  </li>
                  <li class="nav-item d-md-none">
                    <form method="post" action="/logout" data-no-pe>
                      <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
                      <button type="submit" class="nav-link w-100 text-start">
                        <span class="nav-link-icon"><i class="ti ti-logout"></i></span>
                        <span class="nav-link-title">Logout</span>
                      </button>
                    </form>
                  </li>
                  {{end}}
                </ul>
              </div>
              {{if .User}}
              <div class="col-auto d-none d-md-block">
                <div class="d-flex align-items-center gap-3">
                  <button type="button" class="js-update-flag d-none btn btn-sm btn-outline-primary" data-update-open>
                    <i class="ti ti-arrow-up-circle me-1"></i><span class="nav-link-title">Update available</span>
                  </button>
                  <dc-notifications>{{template "notify_bell.gohtml" .}}</dc-notifications>
                  <form method="post" action="/logout" data-no-pe>
                    <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
                    <button type="submit" class="nav-link px-0">
                      <i class="ti ti-logout me-1 d-md-none d-lg-inline-block"></i>
                      <span>Logout</span>
                    </button>
                  </form>
                </div>
              </div>
              {{end}}
            </div>
          </div>
        </div>
      </div>
    </header>
    <div class="page-wrapper">
      <div class="page-body">
        <div class="container-xl">
          {{if and .Flash.Message (eq .FlashProject "")}}
          <div class="alert alert-{{if eq .Flash.Level "success"}}success{{else}}danger{{end}} alert-dismissible" role="alert">
            <div class="d-flex">
              <i class="ti {{if eq .Flash.Level "success"}}ti-circle-check{{else}}ti-alert-circle{{end}} me-2 fs-3"></i>
              <div>{{.Flash.Message}}</div>
            </div>
            <a class="btn-close" data-bs-dismiss="alert" aria-label="close"></a>
          </div>
          {{end}}
{{end}}

{{define "app_end.gohtml"}}
        </div>
      </div>
      <footer class="footer footer-transparent d-print-none">
        <div class="container-xl">
          <div class="row text-center align-items-center flex-row-reverse">
            <div class="col-lg-auto ms-lg-auto text-secondary">
              Version {{appVersion}} <dc-update-check id="dc-update" data-version="{{appVersion}}"></dc-update-check>
            </div>
            <div class="col-12 col-lg-auto mt-3 mt-lg-0">
              <a href="/" class="text-secondary text-decoration-none">Dev Cockpit</a>
            </div>
          </div>
        </div>
      </footer>
    </div>
  </div>
  {{template "quicknav.gohtml" .}}
  </div>
</body>
</html>{{end}}
